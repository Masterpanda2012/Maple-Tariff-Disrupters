# Copy to .env and fill in values. Run `SKIP_ENV_VALIDATION=1 npm run build` only when intentionally bypassing checks (e.g. Docker).

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/maple_tariff?schema=public"

# NextAuth / Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
# Production: canonical origin (also used if NEXTAUTH_URL is unset)
# AUTH_URL="https://your-deployment.example"
# NEXTAUTH_URL is supported at runtime via env.js mapping to AUTH_URL

# Public site URL (optional but recommended for absolute links)
# NEXT_PUBLIC_APP_URL="https://your-deployment.example"

# Google OAuth — optional; when both are set, "Continue with Google" appears on login/register.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL or NEXT_PUBLIC_APP_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional: OpenAI for news/report features
# OPENAI_API_KEY=""

# Optional: Diffy integration
# DIFFY_API_KEY=""
# DIFFY_API_URL="https://example.com"

# Optional: protect cron routes
# CRON_SECRET=""
