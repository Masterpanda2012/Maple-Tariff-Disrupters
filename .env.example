# Copy this file to `.env` and replace placeholder values. Never commit real secrets.
# Vercel: add the same variable names under Project → Settings → Environment Variables.

# --- Required ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/maple_tariff?schema=public"
# Vercel Postgres: the platform may set POSTGRES_PRISMA_URL / POSTGRES_URL; the app maps those if DATABASE_URL is unset.

# Auth.js / NextAuth — use ONE of these names (both are read by src/env.js):
AUTH_SECRET="paste-output-of-openssl-rand-base64-32-here"
# NEXTAUTH_SECRET="same-as-auth-secret-optional-alternate-name"

# --- Strongly recommended ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Canonical OAuth callback URL in production if it differs from NEXT_PUBLIC_APP_URL:
# AUTH_URL="https://your-deployment.example"

# --- Google OAuth (optional) — both required to show “Continue with Google” ---
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Business report LLM (at least one provider for “Generate report”) ---
# Optional: force a backend; if unset, first match wins:
# OpenAI → Groq → OpenRouter → Gemini → Ollama Cloud (OLLAMA_API_KEY only).
# Local Ollama (no cloud key): set LLM_PROVIDER=ollama and run `ollama serve`.

# LLM_PROVIDER="groq"

# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"

# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
# OPENROUTER_HTTP_REFERER="https://your-site.example"

# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Ollama Cloud (https://ollama.com — key from ollama.com/settings/keys):
# OLLAMA_API_KEY=""
# OLLAMA_MODEL="gpt-oss:120b"
# Local Ollama only (leave OLLAMA_API_KEY unset):
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# OLLAMA_MODEL="llama3.2"

# --- News feed (Diffy-compatible) ---
# Built-in route: /api/integrations/diffy-feed (Bearer DIFFY_API_KEY).
# Local: set BOTH:
# DIFFY_API_KEY="choose-a-long-random-secret"
# DIFFY_API_URL="http://localhost:3000/api/integrations/diffy-feed"
# Vercel: set DIFFY_API_KEY (+ NEXT_PUBLIC_APP_URL). You can OMIT DIFFY_API_URL;
# the app uses NEXT_PUBLIC_APP_URL + /api/integrations/diffy-feed automatically.
# Optional on Vercel if you need an explicit or external URL:
# DIFFY_API_URL="https://YOUR_PROJECT.vercel.app/api/integrations/diffy-feed"
# Option B — external HTTP API: GET + JSON array (or { articles | data | items | results }) + Bearer DIFFY_API_KEY
# DIFFY_API_KEY=""
# DIFFY_API_URL="https://your-pipeline.example/api/news"

# Vercel Cron: Authorization: Bearer <CRON_SECRET> on /api/cron/*
# CRON_SECRET=""
