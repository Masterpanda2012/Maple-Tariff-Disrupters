# Maple Tariff Disruptors — environment template
# See project-spec.md (Implementation): Diffy news → DB, tagged news → OpenAI → business
# dashboard; marketplace products; business vs. customer accounts (NextAuth).

# Copy to `.env` and fill in values. Never commit real secrets.

# When adding variables, update `/src/env.js` as well.

# --- Public app URL (required in production for absolute URLs / OAuth) ---
# Exposed to the browser as NEXT_PUBLIC_APP_URL (see next.config.ts + src/env.js).
# On Vercel, set this to your deployment URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Database (Prisma) — PostgreSQL required for Vercel/serverless (SQLite is not supported) ---
# Neon (recommended): https://neon.tech — paste the pooled connection string.
# Or Supabase / Vercel Postgres / any Postgres host.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- Auth — business + customer sign-in (project-spec: two account types) ---
# Generate: openssl rand -base64 32
# Reads NEXTAUTH_SECRET first, then AUTH_SECRET.
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# --- OpenAI — LLM summaries & action steps from relevant tagged news ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# --- Diffy — cron-fed news ingestion (project-spec: request news, store in DB) ---
# HTTPS endpoint that returns JSON (array or { articles | data | items | results }).
DIFFY_API_URL="https://example.com/api/news"
DIFFY_API_KEY=""

# --- Secured cron — verify caller when hitting /api/cron/* from Vercel Cron ---
# Set the same value in Vercel → Project → Environment Variables as CRON_SECRET.
# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""
