{
  "name": "maple-tariff-disruptors",
  "version": "0.1.0",
  "private": true,
  "description": "Canadian platform for businesses to navigate tariff-related economic swings and for customers to find and buy Canadian products.",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dev": "prisma generate && next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "pretest": "prisma generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@auth/core": "^0.37.2",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "framer-motion": "^11.18.2",
    "next": "^15.2.3",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^5.23.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^0.1.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.1.0",
    "eslint-config-next": "^0.2.4",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vitest": "^4.1.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  }
}
